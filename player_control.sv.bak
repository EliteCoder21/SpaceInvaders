module player_control (
    input  logic        clk,
    input  logic        reset,
    input  logic        btn_left,
    input  logic        btn_right,
    output logic [15:0]  shift_reg
);

    // Registers to store previous button states
    logic prev_btn_left;
    logic prev_btn_right;

    // Rising edge detectors
    logic left_edge;
    logic right_edge;

    always_ff @(posedge clk or posedge reset) begin
        if (reset) begin
            shift_reg      <= 16'b16; // Example initial value
            prev_btn_left  <= 1'b1;
            prev_btn_right <= 1'b1;
        end else begin
            // Detect rising edge (button press)
            left_edge  <= btn_left  & ~prev_btn_left;
            right_edge <= btn_right & ~prev_btn_right;

            // Shift based on edge detection
            if (left_edge) begin
                shift_reg <= shift_reg << 1;
            end else if (right_edge) begin
                shift_reg <= shift_reg >> 1;
            end

            // Update previous button states
            prev_btn_left  <= btn_left;
            prev_btn_right <= btn_right;
        end
    end

endmodule

module player_control_testbench();

	logic RST;
	logic [15:0][15:0] RedPixels, GrnPixels;
	
	LED_test dut (.RST, .RedPixels, .GrnPixels);
	
	initial begin
	RST = 1'b1; #10;
	RST = 1'b0; #10;
	end
	
endmodule